{
	"compilerOptions": {
		"target": "ESNext",
		"module": "nodenext",
		"strict": true,
		"verbatimModuleSyntax": true,
		"skipLibCheck": true,
		"types": ["node"],
		"rootDir": "src",
		"outDir": "dist",
		"jsx": "react-jsx",
		"allowSyntheticDefaultImports": true,
		"esModuleInterop": true,
		"moduleResolution": "nodenext",
		"paths": {
			"@utils": ["./src/utils/index.ts"]
		}
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist", ".build"]
}
